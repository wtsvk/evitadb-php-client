{
    "name": "wtsvk/evitadb-php-client",
    "description": "PHP gRPC client for EvitaDB — generated stubs + session-based wrapper.",
    "license": "Apache-2.0",
    "type": "library",
    "keywords": [
        "evitadb",
        "grpc",
        "ecommerce",
        "catalog",
        "nosql"
    ],
    "homepage": "https://github.com/wtsvk/evitadb-php-client",
    "require": {
        "php": "^8.5",
        "ext-grpc": "*",
        "ext-protobuf": "*",
        "google/common-protos": "^4.1",
        "google/protobuf": "^5.34",
        "grpc/grpc": "^1.80",
        "webmozart/assert": "^2.3"
    },
    "require-dev": {
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^13.1",
        "slevomat/coding-standard": "^8.28",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Wtsvk\\EvitaDbClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wtsvk\\EvitaDbClient\\Tests\\": "tests/"
        }
    },
    "extra": {
        "evitadb-version": "2026.1.7"
    },
    "scripts": {
        "phpcs": "./vendor/bin/phpcs",
        "phpcbf": "./vendor/bin/phpcbf",
        "phpstan": "./vendor/bin/phpstan analyse",
        "phpunit": "./vendor/bin/phpunit",
        "check": [
            "@phpcs",
            "@phpstan",
            "@phpunit"
        ],
        "post-autoload-dump": [
            "cd \"$(git rev-parse --show-toplevel)\" && ln -sf ../../scripts/pre-commit.sh .git/hooks/pre-commit"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
